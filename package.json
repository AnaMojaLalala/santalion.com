{
  "name": "santalion-com",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tailwindcss -i ./src/input.css -o ./dist/tailwind.css --minify",
    "watch": "tailwindcss -i ./src/input.css -o ./dist/tailwind.css --watch",
    "dev": "concurrently -k -n tailwind,server -c cyan,magenta \"npm:watch\" \"live-server --port=8080 --no-browser --wait=200\""
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "live-server": "^1.2.2",
    "tailwindcss": "^3.4.17"
  }
}
